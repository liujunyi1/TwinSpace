generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  email         String   @unique
  passwordHash  String
  nickname      String
  avatarUrl     String?
  bio           String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  personalityProfile PersonalityProfile?
  onboardingAnswers   OnboardingAnswer[]
  preferences         Preference[]
  memories            Memory[]
  posts               Post[]
  postLikes           PostLike[]
  comments            Comment[]
  commentLikes        CommentLike[]
  reposts             Repost[]
  following           Follow[] @relation("Following")
  followers           Follow[] @relation("Followers")
  conversationMembers ConversationMember[]
  messages            Message[]
  avatarChatSessions  AvatarChatSession[]
  aiGenerationLogs    AIGenerationLog[]
  avatarProfile       AvatarProfile?
  avatarSources       AvatarKnowledgeSource[]
  avatarKnowledge     AvatarKnowledgePage[]
  avatarCalibrations  AvatarCalibrationCase[]
  avatarAgentSetting  AvatarAgentSetting?
  conversationAgentSettings ConversationAgentSetting[]
  ownedAgentTasks     AgentTask[] @relation("AgentTaskOwner")
  hiddenMessages      MessageHiddenFor[]
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
}

model PersonalityProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  summary               String
  traitsJson            String
  communicationStyle    String
  socialStyle           String
  emotionalStyle        String
  replyLength           String
  emojiPreference       String
  aiAutonomyLevel       String
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AvatarProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  privateName       String    @default("")
  privateAvatarUrl  String?
  status            String    @default("UNBUILT")
  knowledgeRevision Int       @default(0)
  policyRevision    Int       @default(1)
  calibratedAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AvatarKnowledgeSource {
  id        String   @id @default(cuid())
  userId    String
  kind      String
  sourceKey String
  label     String
  content   String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  citations AvatarKnowledgeCitation[]

  @@unique([userId, kind, sourceKey])
  @@index([userId, kind, enabled])
}

model AvatarKnowledgePage {
  id                 String   @id @default(cuid())
  userId             String
  category           String
  title              String
  content            String
  confidence         Float    @default(0.8)
  confirmationStatus String   @default("AUTO")
  enabled            Boolean  @default(true)
  revision           Int      @default(1)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  citations AvatarKnowledgeCitation[]

  @@index([userId, category, confirmationStatus])
}

model AvatarKnowledgeCitation {
  id          String @id @default(cuid())
  knowledgeId String
  sourceId    String

  knowledge AvatarKnowledgePage  @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  source    AvatarKnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([knowledgeId, sourceId])
  @@index([sourceId])
}

model AvatarCalibrationCase {
  id                String   @id @default(cuid())
  userId            String
  kind              String
  scenario          String
  generatedResponse String
  editedResponse    String?
  status            String   @default("GENERATED")
  knowledgeRevision Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind])
  @@index([userId, status, knowledgeRevision])
}

model OnboardingAnswer {
  id          String @id @default(cuid())
  userId      String
  questionKey String
  answerJson  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionKey])
}

model Preference {
  id       String  @id @default(cuid())
  userId   String
  category String
  value    String
  enabled  Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
}

model Memory {
  id          String    @id @default(cuid())
  userId      String
  type        String
  content     String
  sourceType  String
  sourceId    String?
  confidence  Float     @default(0.8)
  status      String    @default("CONFIRMED")
  enabled     Boolean   @default(true)
  confirmedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, status])
}

model Post {
  id             String   @id @default(cuid())
  authorId       String
  content        String
  imageUrlsJson  String   @default("[]")
  topicsJson     String   @default("[]")
  location       String?
  locationLat    Float?
  locationLng    Float?
  visibility     String   @default("PUBLIC")
  allowComments  Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  author   User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes    PostLike[]
  comments Comment[]
  reposts  Repost[]

  @@index([createdAt])
}

model PostLike {
  id     String @id @default(cuid())
  postId String
  userId String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Comment {
  id                String   @id @default(cuid())
  postId            String
  authorId          String
  parentId          String?
  content           String
  generatedByAvatar Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  post    Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies Comment[]     @relation("CommentReplies")
  likes   CommentLike[]

  @@index([postId, createdAt])
}

model CommentLike {
  id        String @id @default(cuid())
  commentId String
  userId    String

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
}

model Repost {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String   @default("")
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String   @id @default(cuid())
  type      String
  title     String
  aiMode    String   @default("MANUAL")
  directKey String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       ConversationMember[]
  messages      Message[]
  agentSettings ConversationAgentSetting[]
  agentTasks    AgentTask[]
  generationLogs AIGenerationLog[]
}

model ConversationMember {
  id             String @id @default(cuid())
  conversationId String
  userId         String
  role           String @default("MEMBER")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String?
  agentTaskId    String?  @unique
  content        String
  senderMode     String   @default("HUMAN")
  createdAt      DateTime @default(now())
  status         String   @default("SENT")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?        @relation(fields: [senderId], references: [id], onDelete: SetNull)
  agentTask    AgentTask?   @relation("AgentTaskOutput", fields: [agentTaskId], references: [id], onDelete: SetNull)
  taskTrigger  AgentTaskTrigger? @relation("AgentTaskTriggerMessage")
  hiddenFor    MessageHiddenFor[]
  generationLogs AIGenerationLog[]

  @@index([conversationId, createdAt])
}

model AvatarAgentSetting {
  id                   String   @id @default(cuid())
  userId               String   @unique
  enabled              Boolean  @default(false)
  defaultMode          String   @default("MANUAL")
  assistAutoDraft      Boolean  @default(false)
  delayMode            String   @default("SHORT")
  customDelaySeconds   Int      @default(60)
  sendBufferSeconds    Int      @default(15)
  timezone             String   @default("Asia/Shanghai")
  activeWindowsJson    String   @default("[]")
  receiveAi            Boolean  @default(true)
  policyRevision       Int      @default(1)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConversationAgentSetting {
  id                   String   @id @default(cuid())
  conversationId       String
  userId               String
  modeOverride         String?
  delayOverride        String?
  customDelaySeconds   Int?
  activeWindowMode     String   @default("INHERIT")
  activeWindowsJson    String?
  receiveAiFromContact String   @default("INHERIT")
  revision             Int      @default(1)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, updatedAt])
}

model AgentTask {
  id               String    @id @default(cuid())
  ownerId          String
  conversationId   String
  kind             String
  status           String    @default("PENDING")
  activeKey        String?   @unique
  idempotencyKey   String    @unique
  runAt            DateTime
  readyAt          DateTime?
  leaseToken       String?
  leaseUntil       DateTime?
  attempts         Int       @default(0)
  maxAttempts      Int       @default(3)
  draftContent     String?
  cancelReason     String?
  error            String?
  model            String?
  policyRevision   Int       @default(1)
  knowledgeRevision Int      @default(0)
  contentExpiresAt DateTime?
  redactedAt       DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  owner         User               @relation("AgentTaskOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  conversation  Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  triggers      AgentTaskTrigger[]
  outputMessage Message?           @relation("AgentTaskOutput")
  generationLogs AIGenerationLog[]

  @@index([status, runAt])
  @@index([ownerId, status, createdAt])
  @@index([conversationId, status])
}

model AgentTaskTrigger {
  id        String   @id @default(cuid())
  taskId    String
  messageId String   @unique
  createdAt DateTime @default(now())

  task    AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  message Message   @relation("AgentTaskTriggerMessage", fields: [messageId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

model AgentWorkerHeartbeat {
  id         String   @id
  status     String   @default("ONLINE")
  startedAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model MessageHiddenFor {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, createdAt])
}

model AvatarChatSession {
  id        String   @id @default(cuid())
  userId    String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AvatarChatMessage[]
}

model AvatarChatMessage {
  id               String   @id @default(cuid())
  sessionId        String
  role             String
  content          String
  status           String   @default("COMPLETE")
  replyToMessageId String?
  createdAt        DateTime @default(now())

  session AvatarChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model AIGenerationLog {
  id                 String   @id @default(cuid())
  userId             String
  taskType           String
  sourceId           String?
  agentTaskId        String?
  conversationId     String?
  messageId          String?
  inputSummary       String?
  output             String?
  accepted           Boolean  @default(false)
  finalEditedContent String?
  model              String?
  status             String   @default("SUCCEEDED")
  policyRevision     Int?
  knowledgeRevision  Int?
  error               String?
  expiresAt           DateTime?
  redactedAt          DateTime?
  createdAt          DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentTask    AgentTask?    @relation(fields: [agentTaskId], references: [id], onDelete: SetNull)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message      Message?      @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([agentTaskId])
  @@index([expiresAt])
}
