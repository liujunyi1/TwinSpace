DATABASE_URL="file:./dev.db"
AUTH_SECRET="replace-with-a-long-random-secret"

# Mock mode works without any AI key.
AI_PROVIDER="mock"
AI_BASE_URL=""
AI_API_KEY=""
AI_MODEL=""
AI_IMAGE_MODEL=""
AI_CAPABILITIES="text"

# Add stream when the OpenAI-compatible endpoint supports SSE:
# AI_CAPABILITIES="text,stream"
# Add image only when the configured model accepts image inputs:
# AI_CAPABILITIES="text,image,stream"

# OpenAI-compatible fallback names are also supported by the app:
# OPENAI_BASE_URL=""
# OPENAI_API_KEY=""
# OPENAI_MODEL=""
